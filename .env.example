# Required application database. Use the pooled URL at runtime.
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=verify-full"

# Recommended for Prisma migrations and administrative database commands.
DATABASE_URL_UNPOOLED="postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=verify-full"

# Admin authentication.
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="replace-with-a-long-random-secret"

# Optional email delivery for booking notices and password resets.
RESEND_API_KEY=""
ADMIN_NOTIFICATION_EMAIL=""

# Required only when running `npm run db:seed-admin`.
ADMIN_SEED_NAME="Admin User"
ADMIN_SEED_EMAIL="admin@example.com"
ADMIN_SEED_PASSWORD="replace-with-at-least-12-characters"
