{
  "name": "rainforest21automotive",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": "^20.19.0 || ^22.13.0 || >=24.0.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "build:cloudflare": "opennextjs-cloudflare build && node scripts/patch-open-next-worker.mjs",
    "start": "next start",
    "lint": "eslint .",
    "postinstall": "prisma generate",
    "prisma:local": "if [ -f .env.local ]; then set -a; . ./.env.local; set +a; fi; if [ -n \"$DATABASE_URL_UNPOOLED\" ]; then export DATABASE_URL=\"$DATABASE_URL_UNPOOLED\"; fi; prisma",
    "db:generate": "npm run prisma:local -- generate",
    "db:migrate:status": "npm run prisma:local -- migrate status",
    "db:migrate:deploy": "npm run prisma:local -- migrate deploy",
    "db:seed-admin": "node --loader ts-node/esm scripts/seed-admin.ts",
    "db:studio": "npm run prisma:local -- studio",
    "update:makes": "NODE_OPTIONS='--loader ts-node/esm' node scripts/fetchCarMakes.ts"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/modifiers": "^9.0.0",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@heroicons/react": "^2.2.0",
    "@prisma/adapter-pg": "^7.9.0",
    "@prisma/client": "^7.9.0",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toggle": "^1.1.10",
    "@radix-ui/react-toggle-group": "^1.1.11",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tabler/icons-react": "^3.41.1",
    "@tanstack/react-table": "^8.21.3",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "dayjs": "^1.11.20",
    "jspdf": "^4.2.1",
    "lucide-react": "^1.7.0",
    "motion": "^12.38.0",
    "next": "^16.2.11",
    "next-auth": "^4.24.15",
    "next-themes": "^0.4.6",
    "node-fetch": "^3.3.2",
    "react": "^19.2.4",
    "react-day-picker": "^9.14.0",
    "react-dom": "^19.2.4",
    "react-hook-form": "^7.72.1",
    "recharts": "^3.8.1",
    "resend": "^6.17.2",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "vaul": "^1.1.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@opennextjs/cloudflare": "^1.20.2",
    "@tailwindcss/postcss": "^4.2.2",
    "@tsconfig/node20": "^20.1.9",
    "@types/node": "^20.19.39",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "dotenv": "^17.4.1",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.11",
    "prisma": "^7.9.0",
    "tailwindcss": "^4.2.2",
    "ts-node": "^10.9.2",
    "tw-animate-css": "^1.4.0",
    "typescript": "^6.0.2",
    "wrangler": "^4.113.0"
  },
  "overrides": {
    "postcss": "8.5.21",
    "sharp": "0.35.3"
  }
}
