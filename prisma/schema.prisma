generator client {
  provider      = "prisma-client"
  output        = "../lib/generated/prisma"
  engineType    = "client"
  runtime       = "cloudflare"
  compilerBuild = "small"
}

datasource db {
  provider = "postgresql"
}

model Booking {
  id                  String   @id @default(cuid())
  name                String
  email               String
  phone               String
  reason              String?
  make                String?
  model               String?
  trim                String?
  year                String?
  problemDescription  String?
  date                String? // Store as "YYYY-MM-DD"
  time                String? // Store as "h:mm A"
  additionalDetails   String?
  acceptTerms         Boolean
  enableNotifications Boolean
  dropOffOrWait       String?
  createdAt           DateTime @default(now()) // UTC by default
  updatedAt           DateTime @updatedAt
  inspections         VehicleInspection[]

  @@index([date, time]) // For fast lookup
  @@unique([date, time])
}

model VehicleInspection {
  id                String   @id @default(cuid())
  inspectionNumber  String   @unique
  bookingId         String?
  booking           Booking? @relation(fields: [bookingId], references: [id], onDelete: SetNull)
  status            String   @default("draft")
  inspectionDate    String
  technicianName    String
  customerName      String
  customerEmail     String?
  customerPhone     String?
  year              String
  make              String
  model             String
  trim              String?
  vin               String
  licensePlate      String?
  mileage           String?
  fuelLevel         String?
  repairOrderNumber String?
  customerConcern   String?
  roadTestNotes     String?
  mechanicSummary   String?
  recommendations   String?
  overallRating     String   @default("good")
  items             Json
  certified         Boolean  @default(false)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([inspectionDate, status])
  @@index([customerName])
  @@index([vin])
  @@index([bookingId])
}

model User {
  id        String   @id @default(cuid())
  name      String?
  email     String   @unique
  password  String // hashed with bcrypt
  role      String   @default("admin") // e.g., "admin", "user"
  createdAt DateTime @default(now())

  resetToken       String?   @unique
  resetTokenExpiry DateTime?
}

model RequestThrottle {
  key          String   @id
  count        Int
  windowStart  DateTime
  blockedUntil DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}
